# ============================================
# LabaLab — Environment Variables (spec §7)
# Salin file ini menjadi .env.local lalu isi nilainya.
# ============================================

# --- Supabase ---
# Dari Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key: RAHASIA, hanya dipakai server (webhook Midtrans dll)
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic ---
# TIDAK PERNAH dikirim ke client — hanya dipakai di API route server-side
ANTHROPIC_API_KEY=

# --- Midtrans ---
# Dari Midtrans Dashboard → Settings → Access Keys
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=
# false = Sandbox (untuk testing), true = Production
MIDTRANS_IS_PRODUCTION=false

# --- App ---
# Dev: http://localhost:3000 — Production: https://labalab.id
NEXT_PUBLIC_APP_URL=http://localhost:3000
